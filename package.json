    "prisma:migrate": "prisma migrate dev",
    "seed": "npm run build && node dist/scripts/seedAdmin.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
