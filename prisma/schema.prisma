generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String    @id @default(cuid())
  email                       String    @unique
  name                        String
  role                        String    @default("admin")
  passwordHash                String?
  salt                        String?
  authProvider                String    @default("email")
  googleId                    String?   @unique
  emailVerified               Boolean   @default(false)
  emailVerificationToken      String?   @unique
  emailVerificationExpiresAt  DateTime?
  emailVerificationLastSentAt DateTime?
  emailVerificationSendCount  Int       @default(0)
  emailVerificationWindowStart DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  lessons                  Lesson[]                       @relation("LessonAuthor")
  createdVocabularyEntries VocabularyEntry[]              @relation("VocabularyCreator")
  learnerVocabulary        LearnerVocabulary[]
  lessonDictionaryStatuses LearnerLessonDictionaryEntry[]
  progressEvents           LearnerProgressEvent[]
  refreshTokens            AuthRefreshToken[]
}

model Lesson {
  id                             String                         @id @default(cuid())
  title                          String
  description                    String?
  status                         LessonStatus                   @default(DRAFT)
  publishedAt                    DateTime?
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  authorId                       String
  author                         User                           @relation("LessonAuthor", fields: [authorId], references: [id])
  items                          LessonItem[]
  dictionaryEntries              LessonDictionaryEntry[]
  learnerLessonDictionaryEntries LearnerLessonDictionaryEntry[]
}

model LessonItem {
  id                String                  @id @default(cuid())
  lessonId          String
  lesson            Lesson                  @relation(fields: [lessonId], references: [id])
  order             Int
  text              String
  audioUrl          String
  segments          Json
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  dictionaryEntries LessonDictionaryEntry[] @relation("LessonItemDictionarySource")

  @@unique([lessonId, order])
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

model VocabularyEntry {
  id                             String                         @id @default(cuid())
  englishText                    String
  kind                           VocabularyKind                 @default(WORD)
  notes                          String?
  tags                           String[]
  createdById                    String?
  createdBy                      User?                          @relation("VocabularyCreator", fields: [createdById], references: [id])
  translations                   VocabularyTranslation[]
  learnerWords                   LearnerVocabulary[]
  lessonDictionaryEntries        LessonDictionaryEntry[]
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  learnerLessonDictionaryEntries LearnerLessonDictionaryEntry[]
}

model VocabularyTranslation {
  id           String          @id @default(cuid())
  entryId      String
  languageCode String
  translation  String
  usageExample String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  entry        VocabularyEntry @relation(fields: [entryId], references: [id])
}

model LearnerVocabulary {
  id        String            @id @default(cuid())
  userId    String
  entryId   String
  status    LearnerWordStatus @default(NEW)
  addedAt   DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id])
  entry     VocabularyEntry   @relation(fields: [entryId], references: [id])

  @@unique([userId, entryId])
}

enum VocabularyKind {
  WORD
  PHRASE
  SENTENCE
}

enum LearnerWordStatus {
  NEW
  REVIEWING
  MASTERED
}

model LessonDictionaryEntry {
  id              String                         @id @default(cuid())
  lessonId        String
  lesson          Lesson                         @relation(fields: [lessonId], references: [id])
  entryId         String
  entry           VocabularyEntry                @relation(fields: [entryId], references: [id])
  order           Int
  sourceItemId    String?
  sourceItem      LessonItem?                    @relation("LessonItemDictionarySource", fields: [sourceItemId], references: [id])
  notes           String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  learnerStatuses LearnerLessonDictionaryEntry[]

  @@unique([lessonId, entryId])
  @@unique([lessonId, order])
  @@index([entryId])
  @@index([lessonId, sourceItemId])
}

model LearnerLessonDictionaryEntry {
  id                String                        @id @default(cuid())
  userId            String
  user              User                          @relation(fields: [userId], references: [id])
  lessonId          String
  lesson            Lesson                        @relation(fields: [lessonId], references: [id])
  entryId           String
  entry             VocabularyEntry               @relation(fields: [entryId], references: [id])
  dictionaryEntryId String?
  dictionaryEntry   LessonDictionaryEntry?        @relation(fields: [dictionaryEntryId], references: [id])
  status            LearnerLessonDictionaryStatus @default(NEW)
  rightSwipes       Int                           @default(0)
  leftSwipes        Int                           @default(0)
  lastReviewedAt    DateTime?
  firstSeenAt       DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@unique([userId, lessonId, entryId])
  @@index([userId, lessonId, status])
  @@index([lessonId, entryId])
}

enum LearnerLessonDictionaryStatus {
  NEW
  LEARNING
  LEARNED
}

model LearnerProgressEvent {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  lessonId        String
  lessonItemId    String?
  eventType       ProgressEventType
  completion      Int?
  clientTimestamp DateTime?
  idempotencyKey  String            @unique
  payload         Json?
  createdAt       DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([lessonId, createdAt])
}

enum ProgressEventType {
  ITEM_STARTED
  ITEM_COMPLETED
  LESSON_COMPLETED
}

model AppSettings {
  id                     String   @id @default("global")
  unknownWordRepetitions Int      @default(2)
  mainTextFontFamily     String   @default("System")
  mainTextFontSize       Int      @default(18)
  translationFontFamily  String   @default("System")
  translationFontSize    Int      @default(12)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AuthRefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}
