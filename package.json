    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "prisma": "^6.19.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
