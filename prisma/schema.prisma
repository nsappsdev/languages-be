generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String    @id @default(cuid())
  email                        String    @unique
  name                         String
  role                         String    @default("admin")
  passwordHash                 String?
  salt                         String?
  authProvider                 String    @default("email")
  googleId                     String?   @unique
  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationExpiresAt   DateTime?
  emailVerificationLastSentAt  DateTime?
  emailVerificationSendCount   Int       @default(0)
  emailVerificationWindowStart DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  lessons                        Lesson[]                          @relation("LessonAuthor")
  learnerLessonVocabularyEntries LearnerLessonVocabularyEntry[]
  vocabularyReviewDecisions      LearnerVocabularyReviewDecision[]
  progressEvents                 LearnerProgressEvent[]
  refreshTokens                  AuthRefreshToken[]
}

model Lesson {
  id                             String                            @id @default(cuid())
  title                          String
  description                    String?
  status                         LessonStatus                      @default(DRAFT)
  publishedAt                    DateTime?
  createdAt                      DateTime                          @default(now())
  updatedAt                      DateTime                          @updatedAt
  authorId                       String
  author                         User                              @relation("LessonAuthor", fields: [authorId], references: [id])
  items                          LessonItem[]
  vocabularyEntries              LessonVocabularyEntry[]
  learnerLessonVocabularyEntries LearnerLessonVocabularyEntry[]
  vocabularyReviewDecisions      LearnerVocabularyReviewDecision[]
}

model LessonItem {
  id                String                  @id @default(cuid())
  lessonId          String
  lesson            Lesson                  @relation(fields: [lessonId], references: [id])
  order             Int
  text              String
  audioUrl          String
  segments          Json
  wordTimings       Json                    @default("[]")
  sentenceTimings   Json                    @default("[]")
  chunkTimings      Json                    @default("[]")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  vocabularyEntries LessonVocabularyEntry[] @relation("LessonItemVocabularySource")

  @@unique([lessonId, order])
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum VocabularyKind {
  WORD
  PHRASE
  SENTENCE
}

model LessonVocabularyEntry {
  id                  String                            @id @default(cuid())
  lessonId            String
  lesson              Lesson                            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  sourceItemId        String?
  sourceItem          LessonItem?                       @relation("LessonItemVocabularySource", fields: [sourceItemId], references: [id], onDelete: SetNull)
  englishText         String
  normalizedText      String
  focusText           String?
  focusNormalizedText String?
  kind                VocabularyKind                    @default(WORD)
  order               Int
  notes               String?
  tags                String[]
  translations        LessonVocabularyTranslation[]
  learnerStatuses     LearnerLessonVocabularyEntry[]
  reviewDecisions     LearnerVocabularyReviewDecision[]
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt

  @@unique([lessonId, normalizedText])
  @@unique([lessonId, order])
  @@index([lessonId, sourceItemId])
}

model LessonVocabularyTranslation {
  id           String                @id @default(cuid())
  entryId      String
  entry        LessonVocabularyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  languageCode String
  translation  String
  usageExample String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([entryId, languageCode])
}

model LearnerLessonVocabularyEntry {
  id             String                        @id @default(cuid())
  userId         String
  user           User                          @relation(fields: [userId], references: [id])
  lessonId       String
  lesson         Lesson                        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  entryId        String
  entry          LessonVocabularyEntry         @relation(fields: [entryId], references: [id], onDelete: Cascade)
  status         LearnerLessonVocabularyStatus @default(NEW)
  correctStreak  Int                           @default(0)
  rightSwipes    Int                           @default(0)
  leftSwipes     Int                           @default(0)
  lastReviewedAt DateTime?
  firstSeenAt    DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@unique([userId, lessonId, entryId])
  @@index([userId, lessonId, status])
  @@index([lessonId, entryId])
}

enum LearnerLessonVocabularyStatus {
  NEW
  LEARNING
  LEARNED
}

model LearnerVocabularyReviewDecision {
  id                     String                        @id @default(cuid())
  userId                 String
  user                   User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId               String
  lesson                 Lesson                        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  entryId                String
  entry                  LessonVocabularyEntry         @relation(fields: [entryId], references: [id], onDelete: Cascade)
  decision               VocabularyReviewDecision
  idempotencyKey         String
  resultingStatus        LearnerLessonVocabularyStatus
  resultingCorrectStreak Int
  resultingRightSwipes   Int
  resultingLeftSwipes    Int
  reviewedAt             DateTime
  createdAt              DateTime                      @default(now())

  @@unique([userId, idempotencyKey])
  @@index([userId, lessonId, createdAt])
  @@index([entryId])
}

enum VocabularyReviewDecision {
  AGAIN
  KNOW
}

model LearnerProgressEvent {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  lessonId        String
  lessonItemId    String?
  eventType       ProgressEventType
  completion      Int?
  clientTimestamp DateTime?
  idempotencyKey  String            @unique
  payload         Json?
  createdAt       DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([lessonId, createdAt])
}

enum ProgressEventType {
  ITEM_STARTED
  ITEM_COMPLETED
  LESSON_COMPLETED
}

model AppSettings {
  id                          String   @id @default("global")
  readingModes                Json     @default("[{\"id\":\"introduction\",\"enabled\":true,\"displayName\":\"Introduction\",\"order\":0},{\"id\":\"teaching\",\"enabled\":true,\"displayName\":\"Teaching\",\"order\":1,\"unknownWordRepetitions\":5},{\"id\":\"deep_learning\",\"enabled\":true,\"displayName\":\"Deep Learning\",\"order\":2,\"unknownWordRepetitions\":5,\"repeatSentenceWhenUnknownCountAtLeast\":2,\"sentenceRepetitions\":2}]")
  mainTextFontFamily          String   @default("System")
  mainTextFontSize            Int      @default(18)
  translationFontFamily       String   @default("System")
  translationFontSize         Int      @default(12)
  translationFontMinSize      Int      @default(8)
  translationFontMaxSize      Int      @default(15)
  translationLetterSpacingMin Float    @default(-0.2)
  translationLetterSpacingMax Float    @default(0.8)
  wordRepetitionPauseMs       Int      @default(800)
  updatePolicyEnabled         Boolean  @default(false)
  latestAndroidBuildNumber    Int      @default(0)
  minAndroidBuildNumber       Int      @default(0)
  latestIosBuildNumber        Int      @default(0)
  minIosBuildNumber           Int      @default(0)
  androidStoreUrl             String   @default("https://play.google.com/store/apps/details?id=com.nsappsdev.language")
  iosStoreUrl                 String   @default("")
  updateMessage               String   @default("A newer app version is available.")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model AuthRefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}
