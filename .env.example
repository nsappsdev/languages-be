PORT=3000
NODE_ENV=production
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TOKEN_TTL=1h
JWT_REFRESH_TOKEN_TTL=30d
ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/language_app"
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME="Admin User"
APP_BASE_URL=https://lezoo.app

# Email verification (Resend HTTP API — https://resend.com)
SMTP_FROM=noreply@lezoo.app
SMTP_PASS=your_api_key_here
SMTP_HOST=smtp.resend.com                                                                                                          
SMTP_PORT=465                                                                                                                      
SMTP_SECURE=true                                                                                                                   
SMTP_USER=resend 